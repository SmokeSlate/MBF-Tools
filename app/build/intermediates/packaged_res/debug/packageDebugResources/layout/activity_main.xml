<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open Android Settings targets"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingBottom="8dp"/>

    <Button
        android:id="@+id/btnOpenSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open Settings"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnOpenDeveloperSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open Developer Settings"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/labelDiscovered"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Discovered exported activities (tap to try):"
        android:layout_marginTop="12dp"
        android:textStyle="bold"/>

    <ScrollView
        android:id="@+id/scrollDiscovered"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:id="@+id/containerActivities"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>

    <TextView
        android:id="@+id/txtLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textIsSelectable="true"
        android:background="#1A000000"
        android:padding="8dp"
        android:textSize="12sp"
        android:typeface="monospace"/>

  </LinearLayout>
